{
  "name": "asset-manager",
  "version": "3.3.3",
  "private": true,
  "scripts": {
    "tunnel:start": "ssh -o StrictHostKeyChecking=accept-new -i ~/.ssh/shinvps-20260215 -L 3307:localhost:3306 -p 19622 -f -N guchi@162.43.74.7",
    "tunnel:kill": "fuser -k 3307/tcp || true",
    "tunnel:check": "lsof -i :3307 || echo 'No tunnel running'",
    "db:up": "bash scripts/db-local.sh up",
    "db:up:docker": "DB_BACKEND=docker bash scripts/db-local.sh up",
    "db:down": "bash scripts/db-local.sh down",
    "db:status": "bash scripts/db-local.sh status",
    "db:setup": "npm run db:up && bash scripts/with-local-db-env.sh npx prisma db push --accept-data-loss",
    "db:deploy:local": "bash scripts/with-local-db-env.sh npx prisma db push --accept-data-loss",
    "db:reset": "bash scripts/with-local-db-env.sh npx prisma db push --force-reset --accept-data-loss",
    "db:dev": "bash scripts/with-local-db-env.sh npx prisma migrate dev",
    "dev": "op run --env-file=.env.1password.tpl -- bash scripts/construct-database-url.sh bash scripts/next-dev.sh",
    "verify:op": "bash scripts/verify-1password-secrets.sh",
    "test:smtp": "bash scripts/test-smtp-send.sh",
    "migrate": "npm run db:dev",
    "prod:tunnel": "npm run tunnel:kill && npm run tunnel:start && op run --env-file=.env.1password.prod.tpl -- bash scripts/construct-database-url.sh bash scripts/next-dev.sh",
    "build": "next build",
    "build:local": "op run --env-file=.env.1password.tpl -- bash scripts/construct-database-url.sh npm run build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test lib/zaim-screenshot/*.test.ts lib/valuation-diff.test.ts lib/valuation-day.test.ts",
    "check": "npm run lint && npm run typecheck && npm run build:local",
    "db:deploy": "prisma migrate deploy",
    "db:generate-init": "prisma migrate diff --from-empty --to-schema-datamodel prisma/schema.prisma --script"
  },
