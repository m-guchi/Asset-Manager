# ローカル開発用の環境変数（1Password 不要）。
#
# DB・Auth・Google OAuth・通知など、ローカル開発に必要な値はすべてここに平文で保存します
# （.gitignore 済みのためコミットされません）。1Password は本番デプロイと本番 DB 確認にのみ使用します。
#
# セットアップ:
#   1. cp .env.local.example .env.local
#   2. 下記の値を必要に応じて編集
#   3. npm run db:setup
#   4. npm run dev

# ローカル MySQL 接続情報（npm run db:setup のデフォルトと同じ値でよい）
DB_USER=asset_manager
DB_PASSWORD=devpassword
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=asset_manager_dev

# NextAuth セッション暗号化キー（任意の文字列。生成例: openssl rand -hex 32）
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
# スマホ等 LAN 上の別端末からアクセスした場合に、リクエストの Host ヘッダーから
# 正しいコールバックURLを自動判定させるための設定（next-auth v4 の挙動）。
AUTH_TRUST_HOST=true

# Google OAuth（任意。メール＆パスワードでのログインのみなら空でよい）
#   本番とは別の開発用クライアントを Google Cloud Console で作成する:
#   承認済みリダイレクト URI: http://localhost:3000/api/auth/callback/google
#   （スマホから LAN IP で確認する場合は http://<LAN-IP>.sslip.io:3000/api/auth/callback/google も追加）
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# SMTP（任意。未設定の場合、メールはコンソールログ出力になる）
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Google Analytics（任意）
NEXT_PUBLIC_GA_ID=

# Signaly ログイン/登録通知（任意。未設定なら通知をスキップする）
SIGNALY_LOGIN_WEBHOOK_URL=
SIGNALY_REGISTER_WEBHOOK_URL=
